# ─── Database ──────────────────────────────────────────────────
# PostgreSQL connection string for the primary database
DATABASE_URL=postgresql://market:marketplace@localhost:5432/marketplace

# Redis URL for caching, cart sessions, and rate limiting
REDIS_URL=redis://localhost:6379

# ─── Authentication ───────────────────────────────────────────
# JWT secret used to sign and verify user tokens (change in production!)
JWT_SECRET=dev-secret-change-me-in-production-please

# ─── Payment ──────────────────────────────────────────────────
# Stripe secret key for processing payments
STRIPE_SECRET_KEY=your-stripe-secret-key-here

# Stripe webhook secret for verifying event signatures
STRIPE_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXX

# ─── AI Chatbot ──────────────────────────────────────────────
# AI provider API key (OpenAI / Anthropic / local LLM endpoint)
AI_API_KEY=sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# AI model name to use
AI_MODEL=gpt-4o
# AI base URL (change for local models like Ollama: http://localhost:11434/v1)
AI_BASE_URL=https://api.openai.com/v1

# ─── Shipping ─────────────────────────────────────────────────
# EasyPost / Shippo API key for carrier rating and label generation
SHIPPING_API_KEY=shippo_test_XXXXXXXXXXXXXXXXXXXXXXXX

# ─── Frontend ─────────────────────────────────────────────────
# Public URL of the backend API (used by Next.js to forward requests)
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── General ──────────────────────────────────────────────────
# Node environment
NODE_ENV=development